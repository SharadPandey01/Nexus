# Nexus Backend Configuration
# ---------------------------

# LLM API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
# Render: use /opt/render/project/src/data/nexus.db if using a disk
DATABASE_URL=sqlite:///./data/nexus.db

# CORS Configuration (Critical for split deployment)
# Add your Vercel URL here, e.g., https://nexus-event.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
DEBUG=False
PORT=8000
HOST=0.0.0.0
